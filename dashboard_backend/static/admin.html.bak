<!doctype html><html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>LRP Admin Dashboard</title><link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,700;9..40,900&display=swap" rel="stylesheet"><style>
:root{--bg:#02040a;--panel:#07101b;--panel2:#0b1625;--glass:rgba(10,22,38,.74);--line:#173653;--line2:#245b82;--text:#e8f7ff;--muted:#7d9bb7;--blue:#1c69d4;--cyan:#31d7ff;--lime:#b7ff36;--green:#2dff9a;--amber:#ffd166;--red:#ff416d;--purple:#9f7aea;--shadow:0 0 42px rgba(49,215,255,.12),inset 0 0 38px rgba(28,105,212,.04);font-family:'DM Sans',system-ui,-apple-system,sans-serif}
*{box-sizing:border-box}body{margin:0;min-height:100vh;background:radial-gradient(circle at 50% -12%,rgba(28,105,212,.42),transparent 34rem),radial-gradient(circle at 88% 18%,rgba(49,215,255,.16),transparent 24rem),linear-gradient(180deg,#02040a,#050a12 58%,#02040a);color:var(--text);overflow-x:hidden}
body:before{content:"";position:fixed;inset:0;pointer-events:none;background:linear-gradient(rgba(49,215,255,.035)1px,transparent 1px),linear-gradient(90deg,rgba(49,215,255,.03)1px,transparent 1px);background-size:42px 42px;mask-image:radial-gradient(circle at center,black,transparent 78%)}
.wrap{max-width:1440px;margin:0 auto;padding:18px}.hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;flex-wrap:wrap;gap:10px}
.logo{font-weight:900;letter-spacing:.12em;text-transform:uppercase;font-size:12px;color:var(--cyan);display:flex;align-items:center;gap:8px}
.grid{display:grid;grid-template-columns:repeat(12,1fr);gap:12px;margin-top:10px}
.panel{border:1px solid var(--line);background:linear-gradient(180deg,rgba(11,22,37,.88),rgba(4,8,15,.9));padding:14px;box-shadow:var(--shadow)}
.p3{grid-column:span 3}.p4{grid-column:span 4}.p5{grid-column:span 5}.p6{grid-column:span 6}.p7{grid-column:span 7}.p8{grid-column:span 8}.p12{grid-column:span 12}
h2{margin:0 0 8px;font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:#bfefff}
.metric{font-size:32px;line-height:.9;font-weight:300;letter-spacing:-.06em}.label{color:var(--muted);font-size:11px;margin-top:4px}
.pill{border:1px solid rgba(49,215,255,.28);padding:3px 6px;color:var(--cyan);font-size:9px;text-transform:uppercase;letter-spacing:.1em;font-weight:900;white-space:nowrap}
.ok{color:var(--green);border-color:rgba(45,255,154,.45)}.wait{color:var(--amber);border-color:rgba(255,209,102,.45)}.stop{color:var(--red);border-color:rgba(255,65,109,.45)}
table{width:100%;border-collapse:collapse;font-size:11px}th{text-align:left;text-transform:uppercase;color:var(--muted);font-size:9px;letter-spacing:.12em;padding:6px 4px;border-bottom:1px solid var(--line);font-weight:900}td{padding:6px 4px;border-bottom:1px solid rgba(23,54,83,.3)}
.btn{padding:4px 8px;font-size:9px;text-transform:uppercase;letter-spacing:.1em;font-weight:900;border:1px solid;cursor:pointer;background:0 0;border-radius:0;font-family:inherit}
.btn-cy{color:var(--cyan);border-color:rgba(49,215,255,.4)}.btn-gr{color:var(--green);border-color:rgba(45,255,154,.4)}.btn-rd{color:var(--red);border-color:rgba(255,65,109,.4)}
input,textarea,select{background:#06101b;border:1px solid var(--line);color:var(--text);padding:6px;font-size:11px;font-family:inherit;width:100%;margin-bottom:4px;border-radius:0}
.log-roll{max-height:300px;overflow-y:auto}
.entry{padding:6px 0;border-bottom:1px solid rgba(23,54,83,.3);font-size:11px}
.entry .t{color:var(--muted);font-size:9px}.entry .b{font-weight:700}.entry .n{color:var(--muted);font-size:10px}
.bar-w{height:6px;border:1px solid var(--line);background:#06101b;position:relative;border-radius:2px}
.bar-w i{display:block;height:100%;border-radius:2px}
.statusbar{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:10px}.chip{border:1px solid rgba(49,215,255,.32);background:rgba(49,215,255,.07);padding:5px 8px;font-size:9px;text-transform:uppercase;letter-spacing:.12em;color:var(--cyan);font-weight:900}
.dial-w{width:120px;height:120px;border-radius:50%;display:grid;place-items:center;margin:0 auto;box-shadow:0 0 24px rgba(49,215,255,.18)}.dial-w:before{content:"";width:88px;height:88px;border-radius:50%;background:#06101b;border:1px solid var(--line);position:absolute}.dial-w span{position:relative;font-size:24px;font-weight:300}
@media(max-width:768px){.grid{grid-template-columns:1fr}.p3,.p4,.p5,.p6,.p7,.p8,.p12{grid-column:auto}.wrap{padding:10px}.metric{font-size:26px}}
.tabs{display:flex;gap:4px;margin:10px 0}.tab{padding:6px 12px;border:1px solid var(--line);cursor:pointer;font-size:10px;text-transform:uppercase;letter-spacing:.12em;color:var(--muted);font-weight:900}
.tab.active{color:#fff;border-color:var(--cyan);background:rgba(49,215,255,.08)}.tab:hover{color:#fff;border-color:var(--cyan)}
</style></head><body><div class="wrap" id="app">
<div class="hdr"><div class="logo"><span>LRP</span> Command</div>
<div><span id="liveTime" style="font-size:10px;color:var(--muted)">Loading...</span>
<button class="btn btn-cy" onclick="logout()" style="margin-left:8px">Logout</button></div></div>
<div class="statusbar"><span class="chip ok" id="apiStatus">API ● Connected</span><span class="chip" id="todayLabel">Today</span><span class="chip" id="callerCount">0 callers active</span></div>
<div class="tabs"><div class="tab active" onclick="switchTab('overview')">Overview</div><div class="tab" onclick="switchTab('prospects')">Prospects</div><div class="tab" onclick="switchTab('callers')">Callers</div><div class="tab" onclick="switchTab('commissions')">Commissions</div></div>
<div id="mainContent"></div></div>
<script>
let TOKEN=null,BASE='/api',REFRESH=null;
const API={get:(p)=>fetch(BASE+p,{headers:{Authorization:'Bearer '+TOKEN}}).then(r=>r.json()),
  post:(p,d)=>fetch(BASE+p,{method:'POST',headers:{'Authorization':'Bearer '+TOKEN,'Content-Type':'application/json'},body:JSON.stringify(d)}).then(r=>r.json()),
  form:(p,d)=>fetch(BASE+p,{method:'POST',headers:{'Authorization':'Bearer '+TOKEN},body:d})};

function login(){const u=document.getElementById('lu').value,p=document.getElementById('lp').value;
  fetch(BASE+'/auth/login',{method:'POST',headers:{'Content-Type':'application/x-www-form-urlencoded'},body:'username='+encodeURIComponent(u)+'&pin='+encodeURIComponent(p)})
  .then(r=>{if(!r.ok){alert('Invalid credentials');throw Error('fail')}return r.json()})
  .then(d=>{TOKEN=d.access_token;document.getElementById('app').innerHTML='<div class="wrap"><p>Loading dashboard...</p></div>';init();load()})}

function logout(){TOKEN=null;if(REFRESH)clearInterval(REFRESH);showLogin()}

function showLogin(){document.getElementById('app').innerHTML=`<div style="max-width:360px;margin:60px auto;border:1px solid var(--line);padding:24px;background:var(--panel)">
<h2 style="text-align:center;font-size:16px;color:var(--cyan);margin-bottom:16px">LRP Dashboard</h2>
<input id="lu" placeholder="Username" style="margin-bottom:8px" autocomplete="off">
<input id="lp" type="password" placeholder="PIN (4 digits)" maxlength="4" style="margin-bottom:12px" autocomplete="off">
<button class="btn btn-cy" onclick="login()" style="width:100%;padding:10px">Enter</button></div>`
document.getElementById('lp').addEventListener('keydown',e=>{if(e.key==='Enter')login()})}

function init(){load();REFRESH=setInterval(load,30000)}
function ts(d){d=d||new Date();if(typeof d==='string')d=new Date(d);return d.toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'})}

function load(){if(!TOKEN)return;
  API.get('/kpis/dashboard').then(d=>{if(d.detail)return;renderKPIs(d);renderActivity(d.recent_activity);
    document.getElementById('todayLabel').textContent=new Date().toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric'});
    document.getElementById('callerCount').textContent=d.callers_online+' caller'+(d.callers_online!==1?'s':'')+' active';
    document.getElementById('liveTime').textContent='Updated '+ts();document.getElementById('apiStatus').textContent='API ● Connected'}).catch(()=>{});
  API.get('/calls?date=today&limit=20').then(d=>{if(!d.detail)renderCallLog(d.calls)}).catch(()=>{})}

function renderKPIs(d){const e=document.getElementById('mainContent');
  if(!e.dataset.tab||e.dataset.tab==='overview'){
  e.innerHTML=`<div class="grid">
<div class="panel p3"><h2>Dials Today</h2><div class="metric" style="color:var(--cyan)">${d.dials_today}</div><div class="label">target 100-150</div></div>
<div class="panel p3"><h2>Connects</h2><div class="metric" style="color:var(--green)">${d.connects_today}</div><div class="label">connect rate ${d.connect_rate}%</div></div>
<div class="panel p3"><h2>Interested</h2><div class="metric" style="color:var(--lime)">${d.looms_sent_today}</div><div class="label">${d.loom_rate}% of dials</div></div>
<div class="panel p3"><h2>DNC Rate</h2><div class="metric" style="color:${d.dnc_rate>20?'var(--red)':d.dnc_rate>15?'var(--amber)':'var(--green)'}">${d.dnc_rate}%</div><div class="label">${d.dnc_rate>20?'OVER target':d.dnc_rate>15?'near limit':'good'}</div></div>
<div class="panel p8"><h2>Prospects</h2><div id="prospectPreview">Loading...</div></div>
<div class="panel p4"><h2>Call Log</h2><div class="log-roll" id="callLogList">No calls yet</div></div>
<div class="panel p6"><h2>Top Callers</h2><div id="callerStats">${d.top_callers&&d.top_callers.length?d.top_callers.map(c=>'<div class="entry"><b>'+c.name+'</b> — '+c.dials+' dials, '+c.connects+' connects ('+c.connect_rate+'%)</div>').join(''):'No active callers'}</div></div>
<div class="panel p6"><h2>Dispositions</h2>${Object.entries(d.calls_by_disposition||{}).map(([k,v])=>'<div class="entry"><span class="b">'+k+'</span> <span class="t">'+v+' calls</span></div>').join('')||'No data'}</div>
<div class="panel p12"><h2>Recent Activity</h2><div class="log-roll" id="activityList">No activity yet</div></div>
</div>`;e.dataset.tab='overview'}}

function renderActivity(list){const el=document.getElementById('activityList');if(!el)return;
  el.innerHTML=list.slice(0,15).map(a=>'<div class="entry"><span class="t">'+ts(a.time)+'</span> <b>'+a.caller_name+'</b> → '+a.business_name+' <span class="pill '+(a.disposition.includes('Interested')?'ok':a.disposition.includes('DNC')?'stop':a.disposition.includes('Callback')?'':a.disposition.includes('Voicemail')?'wait':'')+'">'+a.disposition+'</span> '+(a.duration?'('+a.duration+'s)':'')+'</div>').join('')||'No activity today'}

function renderCallLog(calls){const el=document.getElementById('callLogList');if(!el)return;
  el.innerHTML=calls.slice(0,30).map(c=>'<div class="entry"><span class="t">'+ts(c.call_time)+'</span> <span class="b">'+c.business_name+'</span> <span class="pill '+(c.disposition==='talked_interested'?'ok':c.disposition==='dnc'?'stop':c.disposition==='voicemail'?'wait':'')+'">'+c.disposition+'</span>'+(c.notes?'<div class="n">'+c.notes+'</div>':'')+'</div>').join('')||'No calls today'}

function switchTab(tab){
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  event.target.classList.add('active');
  if(tab==='overview')load();
  else if(tab==='prospects')loadProspects();
  else if(tab==='callers')loadCallers();
  else if(tab==='commissions')loadCommissions()}

function loadProspects(){const e=document.getElementById('mainContent');
  API.get('/prospects?limit=100').then(d=>{e.dataset.tab='prospects';
    e.innerHTML=`<div class="grid"><div class="panel p12"><h2>All Prospects (${d.total||0})</h2>
    <div style="margin-bottom:8px;display:flex;gap:6px"><input id="psSearch" placeholder="Search..." style="flex:1" oninput="searchProspects()">
    <select id="psFilter" onchange="searchProspects()"><option value="">All</option><option value="pending">Pending</option><option value="called">Called</option><option value="contacted">Contacted</option><option value="callback_set">Callback Set</option><option value="dnc">DNC</option></select></div>
    <div style="overflow-x:auto"><table><thead><tr><th>Name</th><th>Phone</th><th>City</th><th>Score</th><th>Status</th><th>Assigned</th><th>Last Contact</th></tr></thead><tbody id="prospectBody"></tbody></table></div></div></div>`;
    renderProspects(d.prospects||[])})}

function renderProspects(prospects){
  const tbody=document.getElementById('prospectBody');if(!tbody)return;
  tbody.innerHTML=prospects.map(p=>'<tr><td><b>'+p.business_name+'</b></td><td>'+(p.phone||'')+'</td><td>'+p.city+'</td><td style="color:'+(p.score==='A'?'var(--green)':p.score==='B'?'var(--amber)':'var(--red)')+'">'+p.score+'</td><td>'+p.status+'</td><td>'+(p.assigned_to||'Unassigned')+'</td><td>'+(p.last_contact?new Date(p.last_contact).toLocaleDateString():'—')+'</td></tr>').join('')||'<tr><td colspan="7" style="text-align:center;color:var(--muted)">No prospects found</td></tr>'}

function searchProspects(){const q=document.getElementById('psSearch').value,s=document.getElementById('psFilter').value;
  let url='/prospects?limit=100';if(q)url+='&search='+encodeURIComponent(q);if(s)url+='&status='+s;
  API.get(url).then(d=>renderProspects(d.prospects||[]))}

function loadCallers(){const e=document.getElementById('mainContent');e.dataset.tab='callers';
  API.get('/callers').then(d=>{e.innerHTML=`<div class="grid"><div class="panel p12"><h2>Manage Callers</h2>
    <div style="margin-bottom:10px;display:grid;grid-template-columns:1fr 1fr 1fr auto;gap:6px">
    <input id="ncUser" placeholder="Username"><input id="ncName" placeholder="Full Name"><input id="ncPin" placeholder="PIN (4 digits)" maxlength="4" value="1234">
    <button class="btn btn-gr" onclick="addCaller()">Add</button></div>
    <table><thead><tr><th>Name</th><th>Username</th><th>Dials Today</th><th>Connects</th><th>Rate</th></tr></thead><tbody id="callerBody"></tbody></table></div></div>`;
    const callers=d.callers||[];
    document.getElementById('callerBody').innerHTML=callers.map(c=>'<tr><td><b>'+c.full_name+'</b></td><td>'+c.username+'</td><td>0</td><td>0</td><td>0%</td></tr>').join('')||'<tr><td colspan="5" style="text-align:center;color:var(--muted)">No callers yet</td></tr>'})}

function addCaller(){
  const u=document.getElementById('ncUser').value,n=document.getElementById('ncName').value,p=document.getElementById('ncPin').value;
  if(!u){alert('Username required');return}
  API.post('/callers',{username:u,full_name:n,pin:p}).then(d=>{if(d.detail)alert(d.detail);else{loadCallers();document.getElementById('ncUser').value='';document.getElementById('ncName').value=''}})}

function loadCommissions(){const e=document.getElementById('mainContent');e.dataset.tab='commissions';
  API.get('/commissions/summary').then(s=>{API.get('/commissions').then(d=>{e.innerHTML=`<div class="grid"><div class="panel p6"><h2>Commission Summary</h2>
    <div id="commSummary">${(s.summary||[]).map(c=>'<div class="entry"><b>'+c.name+'</b> — '+c.total_deals+' deals, $'+c.total_commission+' total ('+c.paid_count+' paid)</div>').join('')||'No commissions yet'}</div>
    <div style="margin-top:10px;padding-top:10px;border-top:1px solid var(--line)"><span style="color:var(--cyan);font-size:20px;font-weight:300">Total: $${s.grand_total||0}</span></div></div>
    <div class="panel p6"><h2>All Commissions</h2><div style="overflow-x:auto"><table><thead><tr><th>Caller</th><th>Deal Amount</th><th>Commission</th><th>Status</th><th>Date</th></tr></thead><tbody id="commBody"></tbody></table></div></div></div>`;
    document.getElementById('commBody').innerHTML=(d.commissions||[]).map(c=>'<tr><td>Caller #'+c.caller_id+'</td><td>$'+c.deal_amount+'</td><td style="color:var(--green)">$'+c.commission_amount+'</td><td><span class="pill '+(c.status==='paid'?'ok':'wait')+'">'+c.status+'</span></td><td>'+(c.deal_date?new Date(c.deal_date).toLocaleDateString():'')+'</td></tr>').join('')||'<tr><td colspan="5" style="text-align:center;color:var(--muted)">No commissions</td></tr>'})})}

// Init
showLogin()
</script></body></html>
